rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthed() {
      return request.auth != null;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) ?
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data :
             null;
    }

    function isRoot() {
      return isAuthed() && request.auth.token.email == 'vidal2311usa@gmail.com';
    }

    function isSupervisor() {
      let data = getUserData();
      return isRoot() || (isAuthed() && data != null && data.cargo == 'supervisor');
    }

    function isGerente() {
      let data = getUserData();
      return isAuthed() && data != null && data.cargo == 'gerente';
    }

    function isAuthorizedForCity(cidade) {
      let data = getUserData();
      return isRoot() || isSupervisor() || (isGerente() && data != null && data.cidade == cidade);
    }

    match /usuarios/{uid} {
      allow read: if isAuthed();
      allow create: if isAuthed() && (isRoot() || isSupervisor());
      allow update: if isAuthed() && (
        isRoot() || 
        isSupervisor() || 
        (request.auth.uid == uid && 
         request.resource.data.cargo == resource.data.cargo && 
         request.resource.data.cidade == resource.data.cidade && 
         request.resource.data.ativo == resource.data.ativo
        )
      );
      allow delete: if isAuthed() && (isRoot() || isSupervisor());
    }

    match /cidades/{cidade} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSupervisor();
    }

    match /funcionarios/{id} {
      allow read: if true;
      allow create: if isAuthed() && isAuthorizedForCity(request.resource.data.cidade);
      allow update: if isAuthed() && isAuthorizedForCity(resource.data.cidade) && isAuthorizedForCity(request.resource.data.cidade);
      allow delete: if isAuthed() && isAuthorizedForCity(resource.data.cidade);
    }

    match /estatisticas/{periodo} {
      allow read: if true;
      allow create, update: if isAuthed() && (isRoot() || isSupervisor() || isGerente());
      allow delete: if isAuthed() && (isRoot() || isSupervisor());
    }

    match /settings/{document} {
      allow read: if true;
      allow create, update, delete: if isSupervisor();
    }
  }
}
